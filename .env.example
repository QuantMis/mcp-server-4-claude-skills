# Bearer token required on every request (Authorization: Bearer <token>).
# REQUIRED — the server refuses to start without it.
SKILLS_MCP_BEARER_TOKEN=change-me-to-a-long-random-secret

# Path to the SQLite database file. Created on first run.
SKILLS_MCP_DB_PATH=./skills.db

# Network bind. Behind the OAuth proxy, bind to all interfaces inside the container.
SKILLS_MCP_HOST=0.0.0.0
SKILLS_MCP_PORT=8080
