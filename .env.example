# Copy to .env and set the token:  cp .env.example .env
#
# Generate a strong token:  openssl rand -hex 32

# REQUIRED. Bearer token required on every request (Authorization: Bearer ...).
# The server refuses to start without it.
SKILLS_MCP_BEARER_TOKEN=change-me-to-a-long-random-secret

# Host port to expose the server on (docker compose). The container always
# listens on 8765 internally; this only changes the published host port.
HOST_PORT=8765

# --- Only used when running WITHOUT docker (python -m skills_mcp) ---
# Under docker compose these are fixed by docker-compose.yml; leave commented.
# SKILLS_MCP_DB_PATH=./skills.db
# SKILLS_MCP_HOST=0.0.0.0
# SKILLS_MCP_PORT=8765
